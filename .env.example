# Copie para .env.local e preencha. NUNCA commite .env.local.
# cp .env.example .env.local

# === Supabase ===
# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
# Project Settings > API > service_role (SECRETA — só usada no servidor/seed)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# === Stripe (item 3 — preencher depois) ===
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# === Meta / Facebook Pixel ===
# Gerenciador de Eventos > Fontes de dados > seu Pixel (só dispara em produção).
NEXT_PUBLIC_META_PIXEL_ID=seu_pixel_id_aqui
# Token da Conversions API (server-side, Purchase no webhook InfinitePay).
# Gerenciador de Eventos > seu Pixel > Configurações > Conversions API >
# "Gerar token de acesso". SECRETO — sem NEXT_PUBLIC_.
META_PIXEL_ACCESS_TOKEN=seu_token_capi_aqui
# OPCIONAL: só para validar. Gerenciador de Eventos > seu Pixel > "Eventos de
# teste" → copie o Test Event Code (TESTxxxxx). Enquanto setada, os eventos vão
# pra aba de teste e NÃO contam como conversão. REMOVA antes de rodar campanha.
META_TEST_EVENT_CODE=

# === Google Analytics 4 ===
# Admin > Fluxos de dados > seu stream > ID de medição (só dispara em produção).
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# === App ===
# Dev: http://localhost:3000
# Produção (Vercel): https://aprovus-ibge.vercel.app  (configurado nas env vars da Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Admin ===
# Allowlist de admins (separe por vírgula). SEM NEXT_PUBLIC_ — só no servidor.
# Quem está aqui entra no painel /admin já no 1º login (é promovido no banco).
ADMIN_EMAILS=getvellum@gmail.com

# === Observabilidade (opcional) ===
# Webhook do Discord para alertas de erro em tempo real (paid_missing_email,
# payment_not_confirmed, process_failed, etc.). Server do Discord > Config. do
# canal > Integrações > Webhooks > "Novo webhook" > Copiar URL. SEM NEXT_PUBLIC_.
# Se vazia, os erros só vão para o console da Vercel (degrada em silêncio).
DISCORD_WEBHOOK_URL=

# === Rate limiting (recomendado em produção) ===
# Rate limit por IP em /api/infinitepay/checkout e /webhook. Se NENHUM par
# abaixo estiver setado, cai num limiter EM MEMÓRIA (por instância, some no cold
# start) — protege pouco em serverless. Configure um destes para o correto:
#   Upstash Redis (console.upstash.com > Create Database > REST):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
#   OU Vercel KV (Storage > Create > KV — injeta estas automaticamente):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
