# Copie para .env.local e preencha. NUNCA commite .env.local.
# cp .env.example .env.local

# === Supabase ===
# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
# Project Settings > API > service_role (SECRETA — só usada no servidor/seed)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# === Stripe (item 3 — preencher depois) ===
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# === Meta / Facebook Pixel ===
# Gerenciador de Eventos > Fontes de dados > seu Pixel (só dispara em produção).
NEXT_PUBLIC_META_PIXEL_ID=seu_pixel_id_aqui

# === App ===
# Dev: http://localhost:3000
# Produção (Vercel): https://aprovus-ibge.vercel.app  (configurado nas env vars da Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Admin ===
# Allowlist de admins (separe por vírgula). SEM NEXT_PUBLIC_ — só no servidor.
# Quem está aqui entra no painel /admin já no 1º login (é promovido no banco).
ADMIN_EMAILS=getvellum@gmail.com
